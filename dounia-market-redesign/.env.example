# API Laravel (inchangée) — le frontend ne fait que la consommer
NEXT_PUBLIC_API_URL=https://api.douniamarket.com/api
NEXT_PUBLIC_SITE_URL=https://douniamarket.com

# Active la validation de commande + paiement Paystack ("true" pour ouvrir)
NEXT_PUBLIC_CHECKOUT_PAYMENT_ENABLED=false

# Recherche (optionnel)
NEXT_PUBLIC_MEILISEARCH_HOST=
NEXT_PUBLIC_MEILISEARCH_KEY=
